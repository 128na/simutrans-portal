{
  "name": "simutrans-portal",
  "private": true,
  "type": "module",
  "scripts": {
    "test:front": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:back:unit": "php artisan test --testsuite=Unit --no-ansi",
    "test:back:feature": "php artisan test --testsuite=Feature --no-ansi",
    "test:coverage": "node scripts/run-parallel.js \"front:npm run test:front:coverage\" \"back:npm run test:back:coverage\"",
    "test:front:coverage": "vitest run --coverage --coverage.reporter=json --coverage.reportsDirectory coverage/front",
    "test:back:coverage": "cross-env XDEBUG_MODE=coverage php -d memory_limit=-1 -d xdebug.mode=coverage -d xdebug.start_with_request=yes vendor/bin/phpunit --configuration=phpunit.xml --coverage-clover=coverage/back/clover.xml --coverage-cobertura=coverage/back/cobertura.xml --colors=never",
    "coverage:report": "node scripts/report-coverage.js",
    "test": "node scripts/run-parallel.js \"front:npm run test:front\" \"unit:npm run test:back:unit\" \"feature:npm run test:back:feature\"",
    "build": "vite build",
    "dev": "vite",
    "format": "prettier --write resources/",
    "format:check": "prettier --check resources/",
    "lint": "eslint . --fix",
    "types": "tsc --noEmit",
    "check": "node scripts/run-parallel.js \"types:npm run types\" \"format:npm run format\" \"lint:npm run lint\" \"pint:composer run pint\" \"phpstan:composer run phpstan\"",
    "all": "npm run check && npm run test"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.0",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4",
    "@vitest/ui": "^4",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-blade": "^3.0.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^10",
    "@tailwindcss/vite": "^4.2.2",
    "@tailwindplus/elements": "^1.0.22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.18.1",
    "date-fns": "^4.1.0",
    "laravel-vite-plugin": "^3.0.0",
    "markdown-it": "^14.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.0.0",
    "react-error-boundary": "^6.1.1",
    "recharts": "^3.8.1",
    "sanitize-html": "^2.17.3",
    "tailwind-merge": "^3.5.0",
    "ts-pattern": "^5.9.0",
    "typescript": "^7.0.2",
    "vite": "^8.0.0",
    "zustand": "^5.0.12"
  }
}
